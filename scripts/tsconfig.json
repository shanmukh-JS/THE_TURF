{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": [
      "../apps/web/node_modules/@types"
    ],
    "paths": {
      "@supabase/supabase-js": ["../apps/web/node_modules/@supabase/supabase-js"],
      "dotenv": ["../apps/web/node_modules/dotenv"],
      "path": ["../apps/web/node_modules/@types/node"]
    }
  },
  "include": ["*.ts"]
}
