# Supabase
# URL of your Supabase project (from dashboard)
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-url.supabase.co"
# Anon public key (from dashboard)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Service role key (from dashboard - keep secret)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Razorpay
# Public Razorpay Key ID
NEXT_PUBLIC_RAZORPAY_KEY_ID="your-razorpay-key-id"
# Razorpay Key ID (same as above, used in backend)
RAZORPAY_KEY_ID="your-razorpay-key-id"
# Razorpay Key Secret (from dashboard - keep secret)
RAZORPAY_SECRET="your-razorpay-secret"
# Secret used to verify Razorpay webhooks
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# Redis/BullMQ
# Connection URL for Redis server
REDIS_URL="redis://localhost:6379"

# Email/SMTP
# SMTP Server Hostname
SMTP_HOST="smtp.yourprovider.com"
# SMTP Port (e.g. 587 or 465)
SMTP_PORT="587"
# SMTP Username
SMTP_USER="your-smtp-username"
# SMTP Password
SMTP_PASS="your-smtp-password"
# Default FROM address for outgoing emails
SMTP_FROM="noreply@yourdomain.com"
# Connection timeout in ms
SMTP_TIMEOUT="10000"
# Encryption key for email secrets (32 chars)
EMAIL_ENCRYPTION_KEY="your-32-character-encryption-key"

# Monitoring (Sentry/OpenTelemetry)
# Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
# OpenTelemetry collector endpoint
OTLP_ENDPOINT="http://localhost:4318/v1/traces"

# Misc
# Base URL of the application
BASE_URL="http://localhost:3000"
# Base URL for API routes
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
# Next.js runtime environment
NEXT_RUNTIME="nodejs"
# Node environment (development, production, etc)
NODE_ENV="development"
# Port for workers/API
PORT="8080"
# Generic provider webhook secret
PROVIDER_WEBHOOK_SECRET="your-webhook-secret"

# Misc - Twilio/WhatsApp Notifications
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="your-twilio-phone"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-token"
WHATSAPP_API_VERSION="v16.0"
WHATSAPP_BASE_URL="https://graph.facebook.com"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-id"
WHATSAPP_TEMPLATE_NAME="your-template"

# Misc - Realtime Feature Flags
NEXT_PUBLIC_ENABLE_REALTIME_BOOKINGS="true"
NEXT_PUBLIC_ENABLE_REALTIME_FINANCIALS="true"
NEXT_PUBLIC_ENABLE_REALTIME_NOTIFICATIONS="true"
NEXT_PUBLIC_ENABLE_REALTIME_REFUNDS="true"
NEXT_PUBLIC_ENABLE_REALTIME_REVIEWS="true"
NEXT_PUBLIC_ENABLE_REALTIME_SLOTS="true"

# Misc - Schedulers/Cron Expressions
HEALTH_CHECK_CRON="0 * * * *"
OWNER_PAYABLE_CRON="0 1 * * *"
PAYOUT_BATCH_CRON="0 2 * * *"
QUEUE_CLEANUP_CRON="0 3 * * *"
RECONCILIATION_CRON="0 4 * * *"
SETTLEMENT_SWEEP_CRON="0 5 * * *"
STATEMENT_CRON="0 6 * * *"

# Misc - Chaos Engineering (Testing)
CHAOS_MODE="false"
CHAOS_RAZORPAY_FAIL="false"
CHAOS_REDIS_OFFLINE="false"
CHAOS_REDIS_TIMEOUT="false"
CHAOS_SECRET="your-chaos-secret"
CHAOS_SLOW_DB="false"
CHAOS_SMTP_TIMEOUT="false"

# Misc - Testing Variables
TEST_ADMIN_EMAIL="admin@example.com"
TEST_OWNER_EMAIL="owner@example.com"
TEST_PASSWORD="password123"
TEST_USER_TOKEN="your-test-token"
