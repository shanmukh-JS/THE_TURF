{
  "name": "api",
  "version": "1.0.0",
  "description": "TRUF GAMING REST API — Express + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema=../../packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../../packages/database/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=../../packages/database/prisma/schema.prisma",
    "db:seed": "ts-node -r tsconfig-paths/register src/seed.ts",
    "lint": "echo 'lint ok'",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "keywords": [],
  "author": "TRUF GAMING",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@truf-gaming/database": "*",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.79.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^6.4.17",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
